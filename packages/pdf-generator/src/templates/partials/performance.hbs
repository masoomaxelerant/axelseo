{{!-- Technical Performance --}}
<div class="page">
  {{> page-header title="Technical Performance"}}

  <h2>Core Web Vitals</h2>
  <p class="summary-text" style="margin-bottom: 16px;">
    Core Web Vitals are the key metrics Google uses to measure real-world user experience.
    They directly impact your search rankings.
  </p>

  <div class="cwv-grid">
    {{{cwvBadge "LCP" (formatMs audit.coreWebVitals.lcp.value) "< 2.5s" audit.coreWebVitals.lcp.rating}}}
    {{{cwvBadge "INP" (formatMs audit.coreWebVitals.inp.value) "< 200ms" audit.coreWebVitals.inp.rating}}}
    {{{cwvBadge "CLS" audit.coreWebVitals.cls.value "< 0.1" audit.coreWebVitals.cls.rating}}}
  </div>

  <div class="section-divider"></div>

  <h3>What These Mean</h3>
  <div class="method-grid">
    <div class="method-card">
      <h4 style="color: {{ratingColor audit.coreWebVitals.lcp.rating}}">LCP: Largest Contentful Paint</h4>
      <p>How long it takes for the main content of your page to become visible.
      Your site loads its main content in <strong>{{formatMs audit.coreWebVitals.lcp.value}}</strong>.
      {{#if (eq audit.coreWebVitals.lcp.rating "good")}}This is excellent.{{else}}Aim for under 2.5 seconds.{{/if}}</p>
    </div>
    <div class="method-card">
      <h4 style="color: {{ratingColor audit.coreWebVitals.inp.rating}}">INP: Interaction to Next Paint</h4>
      <p>How quickly your site responds when a user clicks or taps.
      Your site responds in <strong>{{formatMs audit.coreWebVitals.inp.value}}</strong>.
      {{#if (eq audit.coreWebVitals.inp.rating "good")}}This feels snappy.{{else}}Aim for under 200ms.{{/if}}</p>
    </div>
  </div>

  <h3>Performance Score Breakdown</h3>
  <div class="stat-grid">
    <div class="stat-card">
      <div class="stat-value" style="color: {{scoreColor audit.scores.performance}}">{{round audit.scores.performance}}</div>
      <div class="stat-label">Performance</div>
    </div>
    <div class="stat-card">
      <div class="stat-value">{{formatMs audit.siteStructure.avgLoadTimeMs}}</div>
      <div class="stat-label">Avg Load Time</div>
    </div>
    <div class="stat-card">
      <div class="stat-value">{{formatNumber audit.pagesCrawled}}</div>
      <div class="stat-label">Pages Tested</div>
    </div>
  </div>

  {{> page-footer pageNum="4"}}
</div>
